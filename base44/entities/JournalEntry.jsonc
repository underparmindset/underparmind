{
  "name": "JournalEntry",
  "type": "object",
  "properties": {
    "entry_date": {
      "type": "string",
      "format": "date"
    },
    "prompt": {
      "type": "string"
    },
    "entry_text": {
      "type": "string"
    }
  },
  "required": [
    "entry_date"
  ],
  "rls": {
    "create": true,
    "read": {
      "created_by_id": "{{user.id}}"
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "created_by_id": "{{user.id}}"
    }
  }
}