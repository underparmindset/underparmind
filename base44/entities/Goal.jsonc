{
  "name": "Goal",
  "type": "object",
  "properties": {
    "goal_text": {
      "type": "string"
    },
    "measure": {
      "type": "string"
    },
    "horizon": {
      "type": "string",
      "enum": [
        "week",
        "month",
        "quarter"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "hit",
        "missed"
      ],
      "default": "open"
    },
    "resolved_date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "goal_text",
    "horizon"
  ],
  "rls": {
    "create": true,
    "read": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "user_type": "coach"
          }
        },
        {
          "user_condition": {
            "user_type": "parent"
          }
        }
      ]
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "created_by_id": "{{user.id}}"
    }
  }
}