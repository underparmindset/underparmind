{
  "name": "ModuleProgress",
  "type": "object",
  "properties": {
    "module_id": {
      "type": "string"
    },
    "completed": {
      "type": "boolean",
      "default": false
    },
    "completed_date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "module_id"
  ],
  "rls": {
    "create": true,
    "read": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "user_type": "coach"
          }
        },
        {
          "user_condition": {
            "user_type": "parent"
          }
        }
      ]
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "created_by_id": "{{user.id}}"
    }
  }
}